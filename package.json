{
  "name": "model-manager",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3010",
    "dev:clean": "node scripts/clean-cache.mjs && next dev -p 3010",
    "dev:fresh": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "build": "next build",
    "build:clean": "node scripts/clean-cache.mjs && next build",
    "clean": "node scripts/clean-cache.mjs",
    "start": "next start -p 3010",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4"
  }
}
